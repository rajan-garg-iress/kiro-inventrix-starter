# JWT Configuration
# REQUIRED: Secret key for signing JWT tokens (minimum 32 characters)
JWT_SECRET=your-secret-key-here-must-be-at-least-32-characters-long

# Token expiry duration (default: 1h)
# Supported formats: 60s, 30m, 2h, 1d
JWT_EXPIRES_IN=1h

# CORS Configuration
# Comma-separated list of allowed origins (default: http://localhost:5173)
CORS_ORIGINS=http://localhost:5173

# Rate Limiting
# Time window in milliseconds (default: 900000 = 15 minutes)
RATE_LIMIT_WINDOW_MS=900000

# Maximum requests per window for general endpoints (default: 100)
RATE_LIMIT_MAX=100

# Maximum requests per window for auth endpoints (default: 10)
AUTH_RATE_LIMIT_MAX=10

# Server Configuration
PORT=3000
NODE_ENV=development
